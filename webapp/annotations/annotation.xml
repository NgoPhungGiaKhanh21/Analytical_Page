                                    <PropertyValue Property="LocalDataProperty" PropertyPath="DateVendor"/>
                                    <PropertyValue Property="ValueListProperty" String="DateVendor"/>
                                </Record>
                                <Record Type="Common.ValueListParameterDisplayOnly">
                                    <PropertyValue Property="ValueListProperty" String="POCount"/>
                                </Record>
                            </Collection>
                        </PropertyValue>
                    </Record>
                </Annotation>
            </Annotations>

            <Annotations Target="cds_zsd_po_anal.POAnalyType/RelVendor">
                <!-- Chỗ này hiển thị Release (FRGZU) thay vì Rel-Vendor -->
                <Annotation Term="Common.Text" Path="ReleaseComplete">
                    <Annotation Term="UI.TextArrangement" EnumMember="UI.TextArrangementType/TextOnly" />
                </Annotation>
                <Annotation Term="Common.ValueList">
                    <Record Type="Common.ValueListType">
                        <PropertyValue Property="CollectionPath" String="POAnaly"/>
                        <PropertyValue Property="PresentationVariantQualifier" String="PV_RelVendor"/>
                        <PropertyValue Property="Parameters">
                            <Collection>
                                <Record Type="Common.ValueListParameterInOut">
                                    <PropertyValue Property="LocalDataProperty" PropertyPath="RelVendor"/>
                                    <PropertyValue Property="ValueListProperty" String="RelVendor"/>
                                </Record>
                                <Record Type="Common.ValueListParameterDisplayOnly">
                                    <PropertyValue Property="ValueListProperty" String="POCount"/>
                                </Record>
                            </Collection>
                        </PropertyValue>
                    </Record>
                </Annotation>
            </Annotations>

            <Annotations Target="cds_zsd_po_anal.POAnalyType/MatVendor">
                <!-- Chỗ này hiển thị Material thay vì Material-Vendor -->
                <Annotation Term="Common.Text" Path="Material">
                    <Annotation Term="UI.TextArrangement" EnumMember="UI.TextArrangementType/TextOnly" />
                </Annotation>
                <Annotation Term="Common.ValueList">
                    <Record Type="Common.ValueListType">
                        <PropertyValue Property="CollectionPath" String="POAnaly"/>
                        <PropertyValue Property="PresentationVariantQualifier" String="PV_MatVendor"/>
                        <PropertyValue Property="Parameters">
                            <Collection>
                                <Record Type="Common.ValueListParameterInOut">
                                    <PropertyValue Property="LocalDataProperty" PropertyPath="MatVendor"/>
                                    <PropertyValue Property="ValueListProperty" String="MatVendor"/>
