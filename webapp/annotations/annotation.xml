<edmx:Edmx xmlns:edmx="http://docs.oasis-open.org/odata/ns/edmx" Version="4.0">
    <edmx:Reference Uri="https://sap.github.io/odata-vocabularies/vocabularies/Common.xml">
        <edmx:Include Namespace="com.sap.vocabularies.Common.v1" Alias="Common" />
    </edmx:Reference>
    <edmx:Reference Uri="https://sap.github.io/odata-vocabularies/vocabularies/UI.xml">
        <edmx:Include Namespace="com.sap.vocabularies.UI.v1" Alias="UI" />
    </edmx:Reference>
    <edmx:Reference Uri="/sap/opu/odata/sap/ZSB_PO_ANAL/$metadata">
        <edmx:Include Namespace="cds_zsd_po_anal" />
    </edmx:Reference>
    <edmx:DataServices>
        <Schema xmlns="http://docs.oasis-open.org/odata/ns/edm" Namespace="local">
            <Annotations Target="cds_zsd_po_anal.POAnalyType">

                <!-- ========================================================
                     CHART 1: Tổng giá trị PO theo tháng (Column Chart)
                     ======================================================== -->
                <Annotation Term="UI.Chart" Qualifier="ChartPOValueByMonth">
                    <Record Type="UI.ChartDefinitionType">
                        <PropertyValue Property="Title" String="Total PO Value by Month" />
                        <PropertyValue Property="ChartType" EnumMember="UI.ChartType/Column" />
                        <PropertyValue Property="Dimensions">
                            <Collection>
                                <PropertyPath>CreationDate</PropertyPath>
                            </Collection>
                        </PropertyValue>
                        <PropertyValue Property="DimensionAttributes">
                            <Collection>
                                <Record Type="UI.ChartDimensionAttributeType">
                                    <PropertyValue Property="Dimension" PropertyPath="CreationDate" />
                                    <PropertyValue Property="Role" EnumMember="UI.ChartDimensionRoleType/Category" />
                                </Record>
                            </Collection>
                        </PropertyValue>
                        <PropertyValue Property="Measures">
                            <Collection>
                                <PropertyPath>NetAmount</PropertyPath>
                            </Collection>
                        </PropertyValue>
                        <PropertyValue Property="MeasureAttributes">
                            <Collection>
                                <Record Type="UI.ChartMeasureAttributeType">
                                    <PropertyValue Property="Measure" PropertyPath="NetAmount" />
                                    <PropertyValue Property="Role" EnumMember="UI.ChartMeasureRoleType/Axis1" />
                                </Record>
                            </Collection>
                        </PropertyValue>
                    </Record>
                </Annotation>

                <!-- ========================================================
                     CHART 2: Top 5 nhà cung cấp theo số PO (Bar Chart)
                     ======================================================== -->
                <Annotation Term="UI.Chart" Qualifier="ChartTopVendors">
                    <Record Type="UI.ChartDefinitionType">
                        <PropertyValue Property="Title" String="Top 5 Vendors by PO Count" />
                        <PropertyValue Property="ChartType" EnumMember="UI.ChartType/Bar" />
                        <PropertyValue Property="Dimensions">
                            <Collection>
                                <!-- Đã sửa: VendorName -> SupplierName -->
                                <PropertyPath>SupplierName</PropertyPath>
                            </Collection>
                        </PropertyValue>
                        <PropertyValue Property="DimensionAttributes">
                            <Collection>
                                <Record Type="UI.ChartDimensionAttributeType">
                                    <!-- Đã sửa: VendorName -> SupplierName -->
                                    <PropertyValue Property="Dimension" PropertyPath="SupplierName" />
                                    <PropertyValue Property="Role" EnumMember="UI.ChartDimensionRoleType/Category" />
                                </Record>
                            </Collection>
                        </PropertyValue>
                        <PropertyValue Property="Measures">
                            <Collection>
                                <PropertyPath>POCount</PropertyPath>
                            </Collection>
                        </PropertyValue>
                        <PropertyValue Property="MeasureAttributes">
                            <Collection>
                                <Record Type="UI.ChartMeasureAttributeType">
                                    <PropertyValue Property="Measure" PropertyPath="POCount" />
                                    <PropertyValue Property="Role" EnumMember="UI.ChartMeasureRoleType/Axis1" />
                                </Record>
                            </Collection>
                        </PropertyValue>
                    </Record>
                </Annotation>

                <!-- ========================================================
                     CHART 3: Tỷ lệ PO Approved vs Total (Stacked Column)
                     ======================================================== -->
                <Annotation Term="UI.Chart" Qualifier="ChartApprovalRate">
                    <Record Type="UI.ChartDefinitionType">
                        <PropertyValue Property="Title" String="PO Approval: Approved vs Total" />
                        <PropertyValue Property="ChartType" EnumMember="UI.ChartType/ColumnStacked" />
                        <PropertyValue Property="Dimensions">
                            <Collection>
                                <PropertyPath>CreationDate</PropertyPath>
                            </Collection>
                        </PropertyValue>
                        <PropertyValue Property="DimensionAttributes">
                            <Collection>
                                <Record Type="UI.ChartDimensionAttributeType">
                                    <PropertyValue Property="Dimension" PropertyPath="CreationDate" />
                                    <PropertyValue Property="Role" EnumMember="UI.ChartDimensionRoleType/Category" />
                                </Record>
                            </Collection>
                        </PropertyValue>
                        <PropertyValue Property="Measures">
                            <Collection>
                                <PropertyPath>ApprovedCount</PropertyPath>
                                <PropertyPath>POCount</PropertyPath>
                            </Collection>
                        </PropertyValue>
                        <PropertyValue Property="MeasureAttributes">
                            <Collection>
                                <Record Type="UI.ChartMeasureAttributeType">
                                    <PropertyValue Property="Measure" PropertyPath="ApprovedCount" />
                                    <PropertyValue Property="Role" EnumMember="UI.ChartMeasureRoleType/Axis1" />
                                </Record>
                                <Record Type="UI.ChartMeasureAttributeType">
                                    <PropertyValue Property="Measure" PropertyPath="POCount" />
                                    <PropertyValue Property="Role" EnumMember="UI.ChartMeasureRoleType/Axis1" />
                                </Record>
                            </Collection>
                        </PropertyValue>
                    </Record>
                </Annotation>

                <!-- ========================================================
                     CHART 4: Top 10 Materials đặt hàng nhiều nhất (Bar)
                     ======================================================== -->
                <Annotation Term="UI.Chart" Qualifier="ChartTopMaterials">
                    <Record Type="UI.ChartDefinitionType">
                        <PropertyValue Property="Title" String="Top 10 Most Ordered Materials" />
                        <PropertyValue Property="ChartType" EnumMember="UI.ChartType/Bar" />
                        <PropertyValue Property="Dimensions">
                            <Collection>
                                <PropertyPath>Material</PropertyPath>
                            </Collection>
                        </PropertyValue>
                        <PropertyValue Property="DimensionAttributes">
                            <Collection>
                                <Record Type="UI.ChartDimensionAttributeType">
                                    <PropertyValue Property="Dimension" PropertyPath="Material" />
                                    <PropertyValue Property="Role" EnumMember="UI.ChartDimensionRoleType/Category" />
                                </Record>
                            </Collection>
                        </PropertyValue>
                        <PropertyValue Property="Measures">
                            <Collection>
                                <PropertyPath>POCount</PropertyPath>
                            </Collection>
                        </PropertyValue>
                        <PropertyValue Property="MeasureAttributes">
                            <Collection>
                                <Record Type="UI.ChartMeasureAttributeType">
                                    <PropertyValue Property="Measure" PropertyPath="POCount" />
                                    <PropertyValue Property="Role" EnumMember="UI.ChartMeasureRoleType/Axis1" />
                                </Record>
                            </Collection>
                        </PropertyValue>
                    </Record>
                </Annotation>

                <!-- ========================================================
                     CHART 5: Số lượng PO theo FRGZU (Column Chart)
                     ======================================================== -->
                <Annotation Term="UI.Chart" Qualifier="ChartPOByReleaseStatus">
                    <Record Type="UI.ChartDefinitionType">
                        <PropertyValue Property="Title" String="PO Count by Pur Group (FRGZU)" />
                        <PropertyValue Property="ChartType" EnumMember="UI.ChartType/Column" />
                        <PropertyValue Property="Dimensions">
                            <Collection>
                                <PropertyPath>ReleaseComplete</PropertyPath>
                            </Collection>
                        </PropertyValue>
                        <PropertyValue Property="DimensionAttributes">
                            <Collection>
                                <Record Type="UI.ChartDimensionAttributeType">
                                    <PropertyValue Property="Dimension" PropertyPath="ReleaseComplete" />
                                    <PropertyValue Property="Role" EnumMember="UI.ChartDimensionRoleType/Category" />
                                </Record>
                            </Collection>
                        </PropertyValue>
                        <PropertyValue Property="Measures">
                            <Collection>
                                <PropertyPath>POCount</PropertyPath>
                            </Collection>
                        </PropertyValue>
                        <PropertyValue Property="MeasureAttributes">
                            <Collection>
                                <Record Type="UI.ChartMeasureAttributeType">
                                    <PropertyValue Property="Measure" PropertyPath="POCount" />
                                    <PropertyValue Property="Role" EnumMember="UI.ChartMeasureRoleType/Axis1" />
                                </Record>
                            </Collection>
                        </PropertyValue>
                    </Record>
                </Annotation>

                <!-- ========================================================
                     LINE ITEM (Table columns)
                     ======================================================== -->
                <Annotation Term="UI.LineItem">
                    <Collection>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" PropertyPath="CompanyCode" />
                            <PropertyValue Property="Label" String="Company Code" />
                            <Annotation Term="UI.Importance" EnumMember="UI.ImportanceType/High" />
                        </Record>
                        <Record Type="UI.DataField">
                            <!-- Đã sửa: Vendor -> Supplier -->
                            <PropertyValue Property="Value" PropertyPath="Supplier" />
                            <PropertyValue Property="Label" String="Supplier" />
                            <Annotation Term="UI.Importance" EnumMember="UI.ImportanceType/High" />
                        </Record>
                        <Record Type="UI.DataField">
                            <!-- Đã sửa: VendorName -> SupplierName -->
                            <PropertyValue Property="Value" PropertyPath="SupplierName" />
                            <PropertyValue Property="Label" String="Supplier Name" />
                        </Record>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" PropertyPath="Material" />
                            <PropertyValue Property="Label" String="Material" />
                        </Record>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" PropertyPath="MaterialGroup" />
                            <PropertyValue Property="Label" String="Material Group" />
                        </Record>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" PropertyPath="PurchasingGroup" />
                            <PropertyValue Property="Label" String="Purchasing Group" />
                        </Record>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" PropertyPath="Plant" />
                            <PropertyValue Property="Label" String="Plant" />
                        </Record>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" PropertyPath="CreationDate" />
                            <PropertyValue Property="Label" String="Created On" />
                        </Record>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" PropertyPath="CreatedBy" />
                            <PropertyValue Property="Label" String="Created By" />
                        </Record>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" PropertyPath="ReleaseStatus" />
                            <PropertyValue Property="Label" String="Release Status" />
                        </Record>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" PropertyPath="ReleaseComplete" />
                            <PropertyValue Property="Label" String="FRGZU" />
                        </Record>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" PropertyPath="Quantity" />
                            <PropertyValue Property="Label" String="Total Quantity" />
                        </Record>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" PropertyPath="Unit" />
                            <PropertyValue Property="Label" String="Unit" />
                        </Record>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" PropertyPath="NetAmount" />
                            <PropertyValue Property="Label" String="Net Amount" />
                        </Record>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" PropertyPath="Currency" />
                            <PropertyValue Property="Label" String="Currency" />
                        </Record>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" PropertyPath="POCount" />
                            <PropertyValue Property="Label" String="PO Count" />
                        </Record>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" PropertyPath="ApprovedCount" />
                            <PropertyValue Property="Label" String="Approved Count" />
                        </Record>
                    </Collection>
                </Annotation>

                <!-- ========================================================
                     PRESENTATION VARIANT (5 charts + table)
                     ======================================================== -->
                <Annotation Term="UI.PresentationVariant">
                    <Record Type="UI.PresentationVariantType">
                        <PropertyValue Property="Visualizations">
                            <Collection>
                                <AnnotationPath>@UI.Chart#ChartTopVendors</AnnotationPath>
                                <AnnotationPath>@UI.Chart#ChartPOValueByMonth</AnnotationPath>
                                <AnnotationPath>@UI.Chart#ChartApprovalRate</AnnotationPath>
                                <AnnotationPath>@UI.Chart#ChartTopMaterials</AnnotationPath>
                                <AnnotationPath>@UI.Chart#ChartPOByReleaseStatus</AnnotationPath>
                                <AnnotationPath>@UI.LineItem</AnnotationPath>
                            </Collection>
                        </PropertyValue>
                    </Record>
                </Annotation>

                <!-- ========================================================
                     SELECTION FIELDS (Filter Bar)
                     ======================================================== -->
                <Annotation Term="UI.SelectionFields">
                    <Collection>
                        <!-- ĐÃ THÊM: Bắt buộc phải có để OVP truyền Supplier sang ALP -->
                        <PropertyPath>Supplier</PropertyPath>
                        <PropertyPath>Currency</PropertyPath>
                        <PropertyPath>CompanyCode</PropertyPath>
                        <PropertyPath>PlantVendor</PropertyPath>
                        <PropertyPath>DateVendor</PropertyPath>
                        <PropertyPath>MatVendor</PropertyPath>
                        <PropertyPath>RelVendor</PropertyPath>
                        <PropertyPath>MaterialGroup</PropertyPath>
                        <PropertyPath>PurchasingGroup</PropertyPath>
                    </Collection>
                </Annotation>

                <!-- ========================================================
                     VISUAL FILTER CHARTS (4 Biểu đồ)
                     ======================================================== -->
                     
                <!-- 1. Plant & Vendor (Donut) -->
                <Annotation Term="UI.Chart" Qualifier="ChartFilterPlantVendor">
                    <Record Type="UI.ChartDefinitionType">
                        <PropertyValue Property="ChartType" EnumMember="UI.ChartType/Donut"/>
                        <PropertyValue Property="Title" String="Filter by Plant &amp; Vendor"/>
                        <PropertyValue Property="Dimensions">
                            <Collection><PropertyPath>PlantVendor</PropertyPath></Collection>
                        </PropertyValue>
                        <PropertyValue Property="DimensionAttributes">
                            <Collection>
                                <Record Type="UI.ChartDimensionAttributeType">
                                    <PropertyValue Property="Dimension" PropertyPath="PlantVendor"/>
                                    <PropertyValue Property="Role" EnumMember="UI.ChartDimensionRoleType/Category"/>
                                </Record>
                            </Collection>
                        </PropertyValue>
                        <PropertyValue Property="Measures">
                            <Collection><PropertyPath>POCount</PropertyPath></Collection>
                        </PropertyValue>
                        <PropertyValue Property="MeasureAttributes">
                            <Collection>
                                <Record Type="UI.ChartMeasureAttributeType">
                                    <PropertyValue Property="Measure" PropertyPath="POCount"/>
                                    <PropertyValue Property="Role" EnumMember="UI.ChartMeasureRoleType/Axis1"/>
                                </Record>
                            </Collection>
                        </PropertyValue>
                    </Record>
                </Annotation>

                <!-- 2. Date & Vendor (Line) -->
                <Annotation Term="UI.Chart" Qualifier="ChartFilterDateVendor">
                    <Record Type="UI.ChartDefinitionType">
                        <PropertyValue Property="ChartType" EnumMember="UI.ChartType/Line"/>
                        <PropertyValue Property="Title" String="Trend by Date &amp; Vendor"/>
                        <PropertyValue Property="Dimensions">
                            <Collection><PropertyPath>DateVendor</PropertyPath></Collection>
                        </PropertyValue>
                        <PropertyValue Property="DimensionAttributes">
                            <Collection>
                                <Record Type="UI.ChartDimensionAttributeType">
                                    <PropertyValue Property="Dimension" PropertyPath="DateVendor"/>
                                    <PropertyValue Property="Role" EnumMember="UI.ChartDimensionRoleType/Category"/>
                                </Record>
                            </Collection>
                        </PropertyValue>
                        <PropertyValue Property="Measures">
                            <Collection><PropertyPath>POCount</PropertyPath></Collection>
                        </PropertyValue>
                        <PropertyValue Property="MeasureAttributes">
                            <Collection>
                                <Record Type="UI.ChartMeasureAttributeType">
                                    <PropertyValue Property="Measure" PropertyPath="POCount"/>
                                    <PropertyValue Property="Role" EnumMember="UI.ChartMeasureRoleType/Axis1"/>
                                </Record>
                            </Collection>
                        </PropertyValue>
                    </Record>
                </Annotation>

                <!-- 3. Release (FRGZU) & Vendor (Donut) -->
                <Annotation Term="UI.Chart" Qualifier="ChartFilterRelVendor">
                    <Record Type="UI.ChartDefinitionType">
                        <PropertyValue Property="ChartType" EnumMember="UI.ChartType/Donut"/>
                        <PropertyValue Property="Title" String="Filter by FRGZU &amp; Vendor"/>
                        <PropertyValue Property="Dimensions">
                            <Collection><PropertyPath>RelVendor</PropertyPath></Collection>
                        </PropertyValue>
                        <PropertyValue Property="DimensionAttributes">
                            <Collection>
                                <Record Type="UI.ChartDimensionAttributeType">
                                    <PropertyValue Property="Dimension" PropertyPath="RelVendor"/>
                                    <PropertyValue Property="Role" EnumMember="UI.ChartDimensionRoleType/Category"/>
                                </Record>
                            </Collection>
                        </PropertyValue>
                        <PropertyValue Property="Measures">
                            <Collection><PropertyPath>POCount</PropertyPath></Collection>
                        </PropertyValue>
                        <PropertyValue Property="MeasureAttributes">
                            <Collection>
                                <Record Type="UI.ChartMeasureAttributeType">
                                    <PropertyValue Property="Measure" PropertyPath="POCount"/>
                                    <PropertyValue Property="Role" EnumMember="UI.ChartMeasureRoleType/Axis1"/>
                                </Record>
                            </Collection>
                        </PropertyValue>
                    </Record>
                </Annotation>

                <!-- 4. Material & Vendor (Bar) -->
                <Annotation Term="UI.Chart" Qualifier="ChartFilterMatVendor">
                    <Record Type="UI.ChartDefinitionType">
                        <PropertyValue Property="ChartType" EnumMember="UI.ChartType/Bar"/>
                        <PropertyValue Property="Title" String="Filter by Material &amp; Vendor"/>
                        <PropertyValue Property="Dimensions">
                            <Collection><PropertyPath>MatVendor</PropertyPath></Collection>
                        </PropertyValue>
                        <PropertyValue Property="DimensionAttributes">
                            <Collection>
                                <Record Type="UI.ChartDimensionAttributeType">
                                    <PropertyValue Property="Dimension" PropertyPath="MatVendor"/>
                                    <PropertyValue Property="Role" EnumMember="UI.ChartDimensionRoleType/Category"/>
                                </Record>
                            </Collection>
                        </PropertyValue>
                        <PropertyValue Property="Measures">
                            <Collection><PropertyPath>POCount</PropertyPath></Collection>
                        </PropertyValue>
                        <PropertyValue Property="MeasureAttributes">
                            <Collection>
                                <Record Type="UI.ChartMeasureAttributeType">
                                    <PropertyValue Property="Measure" PropertyPath="POCount"/>
                                    <PropertyValue Property="Role" EnumMember="UI.ChartMeasureRoleType/Axis1"/>
                                </Record>
                            </Collection>
                        </PropertyValue>
                    </Record>
                </Annotation>

                <!-- PresentationVariants cho Visual Filters -->
                <Annotation Term="UI.PresentationVariant" Qualifier="PV_PlantVendor">
                    <Record Type="UI.PresentationVariantType">
                        <PropertyValue Property="Visualizations">
                            <Collection><AnnotationPath>@UI.Chart#ChartFilterPlantVendor</AnnotationPath></Collection>
                        </PropertyValue>
                    </Record>
                </Annotation>

                <Annotation Term="UI.PresentationVariant" Qualifier="PV_DateVendor">
                    <Record Type="UI.PresentationVariantType">
                        <PropertyValue Property="Visualizations">
                            <Collection><AnnotationPath>@UI.Chart#ChartFilterDateVendor</AnnotationPath></Collection>
                        </PropertyValue>
                    </Record>
                </Annotation>

                <Annotation Term="UI.PresentationVariant" Qualifier="PV_RelVendor">
                    <Record Type="UI.PresentationVariantType">
                        <PropertyValue Property="Visualizations">
                            <Collection><AnnotationPath>@UI.Chart#ChartFilterRelVendor</AnnotationPath></Collection>
                        </PropertyValue>
                    </Record>
                </Annotation>

                <Annotation Term="UI.PresentationVariant" Qualifier="PV_MatVendor">
                    <Record Type="UI.PresentationVariantType">
                        <PropertyValue Property="Visualizations">
                            <Collection><AnnotationPath>@UI.Chart#ChartFilterMatVendor</AnnotationPath></Collection>
                        </PropertyValue>
                    </Record>
                </Annotation>

            </Annotations>

            <!-- ========================================================
                 VALUE LISTS & TEXT DISPLAY TÙY CHỈNH CHO FILTER 
                 (Phần bạn cần chú ý nhất - Đã thêm Text và TextArrangement)
                 ======================================================== -->
                 
            <Annotations Target="cds_zsd_po_anal.POAnalyType/PlantVendor">
                <!-- Chỗ này giúp Fiori chỉ hiển thị chữ Plant ngắn gọn thay vì nguyên cụm PlantVendor dài thòng -->
                <Annotation Term="Common.Text" Path="Plant">
                    <Annotation Term="UI.TextArrangement" EnumMember="UI.TextArrangementType/TextOnly" />
                </Annotation>
                <Annotation Term="Common.ValueList">
                    <Record Type="Common.ValueListType">
                        <PropertyValue Property="CollectionPath" String="POAnaly"/>
                        <PropertyValue Property="PresentationVariantQualifier" String="PV_PlantVendor"/>
                        <PropertyValue Property="Parameters">
                            <Collection>
                                <Record Type="Common.ValueListParameterInOut">
                                    <PropertyValue Property="LocalDataProperty" PropertyPath="PlantVendor"/>
                                    <PropertyValue Property="ValueListProperty" String="PlantVendor"/>
                                </Record>
                                <Record Type="Common.ValueListParameterDisplayOnly">
                                    <PropertyValue Property="ValueListProperty" String="POCount"/>
                                </Record>
                            </Collection>
                        </PropertyValue>
                    </Record>
                </Annotation>
            </Annotations>

            <Annotations Target="cds_zsd_po_anal.POAnalyType/DateVendor">
                <!-- Chỗ này hiển thị ngày thay vì Date-Vendor -->
                <Annotation Term="Common.Text" Path="CreationDate">
                    <Annotation Term="UI.TextArrangement" EnumMember="UI.TextArrangementType/TextOnly" />
                </Annotation>
                <Annotation Term="Common.ValueList">
                    <Record Type="Common.ValueListType">
                        <PropertyValue Property="CollectionPath" String="POAnaly"/>
                        <PropertyValue Property="PresentationVariantQualifier" String="PV_DateVendor"/>
                        <PropertyValue Property="Parameters">
                            <Collection>
